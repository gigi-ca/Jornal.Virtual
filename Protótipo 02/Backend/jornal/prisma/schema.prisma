generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Noticias {
  id             Int      @id @default(autoincrement())
  titulo         String
  sub_titulo     String
  texto          String
  data_hora      DateTime @default(now())
  atualizar_data DateTime @updatedAt

  comentario Comentario[]
  Midia     Midia[]
  denuncia_noticia Denuncia_noticia[]

  usuarios  Usuarios? @relation(fields: [usuarioId], references: [id])
  usuarioId Int?
  hastag    Hastag?   @relation(fields: [hastagId], references: [id])
  hastagId  Int?
}

model Usuarios {
  id    Int           @id @default(autoincrement())
  nome  String
  senha String
  email String        @unique
  tipo  TiposUsuarios

  noticia    Noticias[]
  comentario Comentario[]
}

enum TiposUsuarios {
  VERIFICADO
  ALUNO
  ADMINISTRADOR
}

model Hastag {
  id        Int    @id @default(autoincrement())
  categoria String

  noticia Noticias[]
}

model Comentario {
  id             Int      @id @default(autoincrement())
  texto          String
  data_hora      DateTime @default(now())
  atualizar_data DateTime @updatedAt

  denuncia_comentario Denuncia_comentario[]

  noticias   Noticias? @relation(fields: [noticiasId], references: [id])
  noticiasId Int?
  usuarios   Usuarios? @relation(fields: [usuarioId], references: [id])
  usuarioId  Int?
}

model Midia {
  id           Int      @id @default(autoincrement())
  nomeOriginal String
  nomeArquivo  String
  mimeType     String
  path         String
  data         DateTime @default(now())

  noticias Noticias? @relation(fields: [noticiasId], references: [id])
  noticiasId Int?
}

model Denuncia_noticia {
  id         Int      @id @default(autoincrement())
  noticias   Noticias? @relation(fields: [noticiasId], references: [id])
  noticiasId Int?
}

model Denuncia_comentario {
  id           Int        @id @default(autoincrement())
  comentario   Comentario? @relation(fields: [comentarioId], references: [id])
  comentarioId Int?
}