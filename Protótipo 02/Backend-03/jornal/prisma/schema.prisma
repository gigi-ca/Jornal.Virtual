generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
 
}

enum TiposUsuarios {
  ALUNO
  VERIFICADO
  ADMINISTRADOR
}

model Usuarios {

  id Int @id @default(autoincrement())

  nome String
  email String @unique
  senha String

  fotoPerfil String?
  template String?

  unidadeEscolar String

  tipo TiposUsuarios

  bio String?

  dataCriacao DateTime @default(now())

  noticias Noticias[]

  publicacoes Publicacoes[]

  comentarios Comentarios[]

  curtidas Curtidas[]

  denunciasPublicacao DenunciasPublicacao[]

  denunciasComentario DenunciasComentario[]
}

model Noticias {

  id Int @id @default(autoincrement())

  titulo String
  subtitulo String?

  texto String

  dataPublicacao DateTime @default(now())

  dataAtualizacao DateTime @updatedAt

  usuarioId Int

  autor Usuarios @relation(fields: [usuarioId], references: [id])

  midias MidiasNoticias[]
}

model MidiasNoticias {

  id Int @id @default(autoincrement())

  nomeOriginal String

  nomeArquivo String

  mimeType String

  path String

  dataUpload DateTime @default(now())

  noticiaId Int

  noticia Noticias @relation(fields: [noticiaId], references: [id], onDelete: Cascade)
}

model Publicacoes {

  id Int @id @default(autoincrement())

  texto String?

  dataPublicacao DateTime @default(now())

  usuarioId Int

  autor Usuarios @relation(fields: [usuarioId], references: [id])

  comentarios Comentarios[]

  curtidas Curtidas[]

  denuncias DenunciasPublicacao[]

  hashtags Hashtags[]

  midias MidiasPublicacoes[]
}

model MidiasPublicacoes {

  id Int @id @default(autoincrement())

  nomeOriginal String

  nomeArquivo String

  mimeType String

  path String

  dataUpload DateTime @default(now())

  publicacaoId Int

  publicacao Publicacoes @relation(fields: [publicacaoId], references: [id], onDelete: Cascade)
}

model Comentarios {

  id Int @id @default(autoincrement())

  texto String

  dataPublicacao DateTime @default(now())

  publicacaoId Int

  publicacao Publicacoes @relation(fields: [publicacaoId], references: [id], onDelete: Cascade)

  usuarioId Int

  autor Usuarios @relation(fields: [usuarioId], references: [id])

  comentarioPaiId Int?

  comentarioPai Comentarios? @relation("RespostaComentario", fields: [comentarioPaiId], references: [id])

  respostas Comentarios[] @relation("RespostaComentario")

  denuncias DenunciasComentario[]
}

model Curtidas {

  id Int @id @default(autoincrement())

  usuarioId Int

  usuario Usuarios @relation(fields: [usuarioId], references: [id])

  publicacaoId Int

  publicacao Publicacoes @relation(fields: [publicacaoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, publicacaoId])
}

model Hashtags {

  id Int @id @default(autoincrement())

  nome String @unique

  dataCriacao DateTime @default(now())

  publicacoes Publicacoes[]
}

model DenunciasPublicacao {

  id Int @id @default(autoincrement())

  motivo String

  dataDenuncia DateTime @default(now())

  publicacaoId Int

  publicacao Publicacoes @relation(fields: [publicacaoId], references: [id], onDelete: Cascade)

  usuarioId Int

  usuario Usuarios @relation(fields: [usuarioId], references: [id])
}

model DenunciasComentario {

  id Int @id @default(autoincrement())

  motivo String

  dataDenuncia DateTime @default(now())

  comentarioId Int

  comentario Comentarios @relation(fields: [comentarioId], references: [id], onDelete: Cascade)

  usuarioId Int

  usuario Usuarios @relation(fields: [usuarioId], references: [id])
}